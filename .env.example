APP_NAME=GANSEKOU
APP_ENV=production
SECRET_KEY=change-this-secret
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/gansecou_db
CORS_ORIGINS=http://localhost:3000
UPLOAD_DIR=uploads

# Firebase Admin: choose one strategy.
# Strategy 1: full service-account JSON in one environment variable.
FIREBASE_CREDENTIALS_JSON=

# Strategy 2: split service-account fields.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Strategy 3: mounted file path inside the container.
FIREBASE_CREDENTIALS_PATH=/run/secrets/firebase_credentials.json
FIREBASE_STORAGE_BUCKET=

OPENAI_API_KEY=
OPENAI_MODEL=deepseek-chat
OPENAI_BASE_URL=https://api.deepseek.com

CAMPAY_BASE_URL=https://demo.campay.net/api
CAMPAY_APP_ID=
CAMPAY_TOKEN=
CAMPAY_WEBHOOK_KEY=

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gansecou_db
